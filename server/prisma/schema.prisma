generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id           String  @id
  date         String
  time         String?
  type         String
  category     String
  subcategory  String?
  vendor       String
  amount       Float
  currency     String?
  source       String?
  memo         String?
  hash         String? @unique
}

model CategoryRule {
  id                String @id
  keyword           String @unique
  assigned_category String
}

model Category {
  id   String @id
  name String @unique
}

model RecurringTransaction {
  id           String @id
  vendor       String
  amount       Float
  category     String
  type         String @default("expense")
  day_of_month Int
}
