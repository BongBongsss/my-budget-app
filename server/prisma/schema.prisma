generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id           String  @id
  date         String
  time         String?
  type         String
  category     String
  subcategory  String?
  vendor       String
  amount       Float
  currency     String?
  source       String?
  memo         String?
  hash         String? @unique
  isVerified   Boolean @default(true)
}

model CategoryRule {
  id                String @id
  keyword           String @unique
  assigned_category String
}

model Category {
  id        String @id
  name      String @unique
  groupName String @default("기타")
}

model CategoryGroupRule {
  id                String @id
  categoryName      String @unique
  assignedGroup     String
}

model PaymentRule {
  id          String @id
  paymentType String // 'card' or 'transfer'
  keyword     String @unique
}

model Session {
  sid    String   @id @unique
  sess   Json
  expire DateTime

  @@map("session")
}

model RecurringTransaction {
  id           String @id
  vendor       String
  amount       Float
  category     String
  type         String @default("expense")
  day_of_month Int
}
