{
  "name": "budget-automation",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Automated Budget Tracking Application",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "test": "vitest",
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client",
    "dev": "npm run dev --workspace=server & npm run dev --workspace=client",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.budget.app",
    "win": {
      "target": "nsis"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "papaparse": "^5.5.3",
    "xlsx": "^0.18.5",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/xlsx": "^0.0.35"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/node-cron": "^3.0.11",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "prisma": "6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
